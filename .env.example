# Contact form (Formspree). Copy this file to `.env` and set your endpoint.
# Create a free form at https://formspree.io and paste the endpoint below.
# When this variable is NOT set, the contact form is hidden and the site
# falls back to the direct Email / LinkedIn / GitHub buttons (no fake "sent").
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id
